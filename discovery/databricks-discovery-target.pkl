amends "@formae/formae.pkl"
import "@databricks/databricks.pkl"

// Discovery target for Databricks workspace.
// Add to your formae config to enable automatic resource discovery.
new Target {
  label = "databricks-workspace"
  config = new databricks.Config {
    host = read("env:DATABRICKS_HOST")
  }
}
