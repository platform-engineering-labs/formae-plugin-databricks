amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@databricks/databricks.pkl"
import "@databricks/compute/cluster.pkl"

local stackName = "plugin-sdk-test-cluster-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for Databricks Cluster"
  }

  new formae.Target {
    label = "databricks-target"
    config = new databricks.Config {
      host = read("env:DATABRICKS_HOST")
    }
  }

  new cluster.Cluster {
    label = "plugin-sdk-test-cluster"
    clusterName = "formae-plugin-sdk-test-\(testRunID)-updated"     // CHANGED
    sparkVersion = "15.4.x-scala2.12"
    nodeTypeId = "i3.xlarge"
    numWorkers = 2                                                   // CHANGED from 1
    autoterminationMinutes = 15                                      // CHANGED from 10
    dataSecurityMode = "SINGLE_USER"
    customTags = new Mapping {
      ["Environment"] = "test"
      ["Updated"] = "true"                                           // ADDED
    }
  }
}
